@model IEnumerable<CollegeInfoPortal.Models.Student>
@{
    ViewData["Title"] = "Students";
}
<h2>Students</h2>
<p><a class="btn btn-primary" href="/Students/Create">Create New</a></p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Department</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach(var s in Model) {
    <tr>
        <td>@s.Name</td>
        <td>@s.Email</td>
        <td>@s.Department?.Name</td>
        <td>
            <a class="btn btn-sm btn-secondary" href="/Students/Edit/@s.StudentId">Edit</a>
            <a class="btn btn-sm btn-danger" href="/Students/Delete/@s.StudentId">Delete</a>
        </td>
    </tr>
}
    </tbody>
</table>