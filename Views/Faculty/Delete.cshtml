@model CollegeInfoPortal.Models.Faculty
@{
    ViewData["Title"] = "Delete Faculty";
}
<h2>Delete Faculty</h2>
<div>
    <h4>Are you sure you want to delete this?</h4>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>
        <dt class="col-sm-2">Designation</dt>
        <dd class="col-sm-10">@Model.Designation</dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="FacultyId" />
        <button class="btn btn-danger" type="submit">Delete</button>
        <a class="btn btn-secondary" href="/Faculty">Cancel</a>
    </form>
</div>