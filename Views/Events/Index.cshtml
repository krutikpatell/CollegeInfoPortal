@model IEnumerable<CollegeInfoPortal.Models.Event>
@{
    ViewData["Title"] = "Events";
}
<h2>Events</h2>
<p><a class="btn btn-primary" href="/Events/Create">Create New</a></p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Date</th>
            <th>Location</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach(var e in Model) {
    <tr>
        <td>@e.Title</td>
        <td>@e.Date.ToShortDateString()</td>
        <td>@e.Location</td>
        <td>
            <a class="btn btn-sm btn-secondary" href="/Events/Edit/@e.EventId">Edit</a>
            <a class="btn btn-sm btn-danger" href="/Events/Delete/@e.EventId">Delete</a>
        </td>
    </tr>
}
    </tbody>
</table>