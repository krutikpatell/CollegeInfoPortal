@model IEnumerable<CollegeInfoPortal.Models.Course>
@{
    ViewData["Title"] = "Courses";
}
<h2>Courses</h2>
<p><a class="btn btn-primary" href="/Courses/Create">Create New</a></p>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Credits</th>
            <th>Department</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach(var c in Model) {
    <tr>
        <td>@c.Title</td>
        <td>@c.Credits</td>
        <td>@c.Department?.Name</td>
        <td>
            <a class="btn btn-sm btn-secondary" href="/Courses/Edit/@c.CourseId">Edit</a>
            <a class="btn btn-sm btn-danger" href="/Courses/Delete/@c.CourseId">Delete</a>
        </td>
    </tr>
}
    </tbody>
</table>